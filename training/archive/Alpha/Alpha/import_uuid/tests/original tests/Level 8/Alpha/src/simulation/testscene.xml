<scene version="2.0.0">
    <!-- Integrator: Bidirectional Path Tracer -->
    <integrator type="bdpt">
        <integer name="max_depth" value="100"/> <!-- Allow for deep light paths -->
        <integer name="rr_depth" value="5"/>    <!-- Russian Roulette depth for efficiency -->
    </integrator>

    <!-- Plane: Default material -->
    <shape type="rectangle">
        <transform name="to_world">
            <scale x="10" y="10" z="1"/>
        </transform>
        <bsdf type="diffuse">
            <rgb name="reflectance" value="0.5, 0.5, 0.5"/>
        </bsdf>
    </shape>

    <!-- Sphere: Default dielectric (glass-like) -->
    <shape type="sphere">
        <float name="radius" value="1.0"/>
        <transform name="to_world">
            <translate x="2" y="0" z="1"/>
        </transform>
        <bsdf type="dielectric">
            <float name="int_ior" value="1.5"/> <!-- Index of refraction (glass) -->
            <float name="ext_ior" value="1.0"/> <!-- Air -->
        </bsdf>
    </shape>

    <!-- Cube: Default rough conductor -->
    <shape type="cube">
        <transform name="to_world">
            <translate x="-2" y="0" z="0.5"/>
            <scale x="1" y="1" z="1"/>
        </transform>
        <bsdf type="roughconductor">
            <float name="alpha" value="0.05"/> <!-- Surface roughness -->
            <string name="material" value="aluminum"/> <!-- Metal material -->
        </bsdf>
    </shape>

    <!-- Light source: Spectral area emitter -->
    <shape type="rectangle">
        <transform name="to_world">
            <scale x="2" y="2" z="1"/>
            <translate x="0" y="5" z="3"/>
        </transform>
        <emitter type="area">
            <spectrum name="radiance" type="regular">
                <float name="wavelength" value="550"/> <!-- Central wavelength -->
                <float name="value" value="50.0"/>    <!-- Intensity -->
            </spectrum>
        </emitter>
    </shape>

    <!-- Projective Camera -->
    <sensor type="perspective">
        <transform name="to_world">
            <look_at origin="0, 5, 10" target="0, 0, 0" up="0, 1, 0"/>
        </transform>
        <sampler type="independent">
            <integer name="sample_count" value="4096"/>
        </sampler>
        <film type="hdrfilm">
            <integer name="width" value="1024"/>
            <integer name="height" value="1024"/>
            <rfilter type="gaussian"/>
        </film>
    </sensor>

    <!-- Light Field Sensor -->
    <sensor type="lightfield">
        <film type="hdrfilm">
            <integer name="width" value="512"/> <!-- Number of samples across horizontal plane -->
            <integer name="height" value="512"/> <!-- Number of samples across vertical plane -->
        </film>
        <sampler type="independent">
            <integer name="sample_count" value="2048"/> <!-- Sample count for high resolution -->
        </sampler>
        <transform name="to_world">
            <look_at origin="0, 0, 10" target="0, 0, 0" up="0, 1, 0"/>
        </transform>
    </sensor>

    <!-- Background emitter -->
    <emitter type="constant">
        <rgb name="radiance" value="0.1, 0.1, 0.1"/> <!-- Low ambient illumination -->
    </emitter>
</scene>
